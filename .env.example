# =============================================================================
# mcp-wikijs-mv — environment configuration
# =============================================================================
# All of these are OPTIONAL on the HTTP/Vercel transport when clients send their
# own credentials per request via headers (see README "Multi-user / BYOK").
# They are REQUIRED for the local stdio transport (single user).
# -----------------------------------------------------------------------------

# Base URL of your Wiki.js instance (no trailing /graphql).
#   e.g. https://wiki.example.org
WIKIJS_URL=

# Wiki.js API key (JWT) used as `Authorization: Bearer <token>`.
# Create one in Wiki.js: Administration → API → enable + create key.
WIKIJS_TOKEN=

# -----------------------------------------------------------------------------
# Permission policy (fine-grained access control)
# -----------------------------------------------------------------------------
# Baseline preset applied at deploy time. One of:
#   readonly   - only read tools, everything else blocked
#   safe       - read=allow, write/delete=confirm, all admin=block   (DEFAULT)
#   editor     - read/write=allow, delete=confirm, all admin=block
#   maintainer - read/write=allow, delete/admin=confirm
#   full       - everything allowed (trust the Wiki.js key's own scopes)
WIKIJS_PERMISSION_PRESET=safe

# Optional JSON override on top of the preset. Per-category and per-tool.
# Modes: "allow" | "confirm" | "block".
# Example: allow page deletes without confirm, but block user management:
#   WIKIJS_POLICY={"categories":{"delete":"allow","manage_users":"block"},"tools":{"wiki_graphql":"block"}}
WIKIJS_POLICY=

# Show blocked tools in tools/list as disabled stubs (they still refuse to run).
# Default false = blocked tools are hidden entirely.
WIKIJS_SHOW_BLOCKED=false

# -----------------------------------------------------------------------------
# Multi-user via named credential profiles (RECOMMENDED proxy mode)
# -----------------------------------------------------------------------------
# Pre-configure multiple users/keys server-side. Each ALIAS is its own handle and
# maps to its own Wiki.js key (with its own Wiki.js rights) + instance + optional
# per-handle policy. The client only ever sends the alias — the real key NEVER
# leaves the server and is never seen by the LLM provider.
#
# Client connects with just the alias as the token:
#   URL param : https://<deploy>/mcp?token=<alias>
#   header    : X-Wikijs-Token: <alias>   (or  Authorization: Bearer <alias>)
#
# JSON: { "<SECRET-HANDLE>": { "label": "...", "url": "...", "token": "<realKey>",
#                              "preset": "editor", "policy": {...} } }
#   - the MAP KEY is the SECRET handle token the user connects with. It MUST be a
#     high-entropy, UNGUESSABLE value (NOT a name) — otherwise anyone could use
#     someone else's handle and inherit their rights. Generate one with:
#         node scripts/gen-profile.mjs "Alice:readonly" "Bob:editor"
#   - label  non-secret human name (shown in audit/connection_status; the secret is never echoed)
#   - url    optional (falls back to WIKIJS_URL)
#   - token  required (the real Wiki.js API key — use a SCOPED key)
#   - preset / policy optional per-handle gate (tighten-only on top of the baseline)
# Example (two users, SAME wiki url, different rights, each its own secret handle):
#   WIKIJS_PROFILES={"wzp_8Qf2…SECRET-A":{"label":"Alice","url":"https://wiki.example.org","token":"KEY_A","preset":"readonly"},"wzp_pK9v…SECRET-B":{"label":"Bob","url":"https://wiki.example.org","token":"KEY_B","preset":"editor"}}
WIKIJS_PROFILES=

# Simpler legacy form (alias -> token string only; url/policy from env/headers).
# Superseded by WIKIJS_PROFILES; kept for backward compatibility.
# JSON object: { "<alias>": "<realToken>", ... }
WIKIJS_KEY_MAP=

# -----------------------------------------------------------------------------
# Misc (optional)
# -----------------------------------------------------------------------------
# Per-request GraphQL timeout in ms (default 30000).
WIKIJS_TIMEOUT_MS=
# Set "true" to log MCP request details (HTTP transport).
WIKIJS_MCP_VERBOSE=
# Override the base URL advertised in /.well-known/mcp.json (else derived from headers).
PUBLIC_BASE_URL=
